{
  "name": "cataclysm-translator",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && node scripts/copy-renderer.mjs",
    "dev": "tsc -w",
    "test": "npm run build && node --test scripts/*.test.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/prepare-runtime-python.mjs && tauri build",
    "verify": "npm run test && powershell -Command \"Push-Location src-tauri; $env:CARGO_TARGET_DIR='target-test'; cargo test; Pop-Location\""
  },
  "dependencies": {
    "opencc-js": "^1.0.5",
    "undici": "^6.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@tauri-apps/cli": "^2.1.0",
    "typescript": "^5.5.4"
  }
}
