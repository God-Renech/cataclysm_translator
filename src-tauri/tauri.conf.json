{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cataclysm Translator",
  "version": "0.3.2",
  "identifier": "com.cataclysm.translator",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../app/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "Cataclysm Translator",
        "width": 1100,
        "height": 800,
        "resizable": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "runtime/**/*"
    ],
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
